{
  "expo": {
    "name": "NutriTiffin",
    "slug": "nutri_customerApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nutritiffincustomer",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nutritiffin.customerapp",
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "tez",
          "gpay",
          "phonepe",
          "paytmmp",
          "bhim",
          "upi"
        ]
      }
    },
    "android": {
      "package": "com.nutritiffin.customerapp",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withPaymentAppQueries.js",
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow NutriTiffin to use your location to detect your delivery address."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow NutriTiffin to access your photos to set your profile picture.",
          "cameraPermission": "Allow NutriTiffin to use the camera for your profile picture."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e9150976-84fd-4f21-abc0-12049d3cbc52"
      },
      "merchantUpiVpa": ""
    }
  }
}
